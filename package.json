{
	"name": "adventure-game-builder",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"start": "vite",
		"build": "tsc --noEmit && vite build",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"ci": "npm run typecheck && npm run test:run && npm run build",
		"preview": "vite preview",
		"prepare": "husky"
	},
	"dependencies": {
		"@vitejs/plugin-react": "^4.3.4",
		"phaser": "^3.87.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"vite": "^6.0.5",
		"zustand": "^5.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"husky": "^9.1.7",
		"jsdom": "^28.1.0",
		"lint-staged": "^16.4.0",
		"typescript": "^5.7.2",
		"vitest": "^4.1.7"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,css,md}": [
			"biome check --write"
		]
	}
}
